{
  "docs": {
    "localIndexEnabled": false,
    "cacheDir": "~/.happy-platform-mcp/docs/servicenow",
    "enableVector": false,
    "embeddingProvider": "none"
  },
  "instances": [
    {
      "name": "dev",
      "url": "https://your-dev-instance.service-now.com",
      "username": "your_dev_username",
      "password": "your_dev_password",
      "default": true,
      "description": "Development instance"
    },
    {
      "name": "prod",
      "url": "https://yourinstance.service-now.com",
      "username": "api_user",
      "password": "your_password",
      "default": false,
      "description": "Production instance"
    },
    {
      "name": "test",
      "url": "https://your-test-instance.service-now.com",
      "username": "test_user",
      "password": "test_password",
      "default": false,
      "description": "Test instance"
    },
    {
      "name": "staging-oauth",
      "url": "https://your-staging-instance.service-now.com",
      "authType": "oauth",
      "grantType": "client_credentials",
      "clientId": "your_oauth_client_id",
      "clientSecret": "your_oauth_client_secret",
      "default": false,
      "description": "Staging instance with OAuth client credentials"
    }
  ]
}
